// Plataforma Impulso — Phase 2
// Mapeia tabelas existentes do Postgres (criadas via n8n) + adiciona usuarios

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Cliente {
  id              Int       @id @default(autoincrement())
  nome            String
  // Razão social ou marca-mãe (compartilhada por todas as contas vinculadas)
  empresa         String?
  // WhatsApp único pra alertas de qualquer conta deste cliente
  whatsappAlerta  String?   @map("whatsapp_alerta")
  // Tipo de serviço prestado pela agência. Valores: panfletagem_digital | gestao_trafego | impulso_360
  tipoServico     String?   @map("tipo_servico")
  // Chave usada pelos workflows n8n (ex: "SC", "altaconquista").
  // Liga este cliente às tabelas fb_meta_insights e impulso.lead_current.
  n8nClientKey    String?   @map("n8n_client_key")
  ativo           Boolean   @default(true)
  criadoEm        DateTime  @default(now()) @map("criado_em") @db.Timestamptz()
  atualizadoEm    DateTime  @default(now()) @map("atualizado_em") @db.Timestamptz()

  // ── CRM / WhatsApp ──────────────────────────────────────────────────────────
  evolutionInstance         String?  @unique @map("evolution_instance")
  // Número WhatsApp para onde o /r/wa/[slug] redireciona leads (ex: "5511999999999")
  waNumero                  String?  @map("wa_numero")
  // Credenciais Facebook CAPI
  pixelId                   String?  @map("pixel_id")
  capiToken                 String?  @map("capi_token")
  // Credenciais Google Ads Offline Conversions
  googleAdsCustomerId                  String?  @map("google_ads_customer_id")
  googleConversionActionId             String?  @map("google_conversion_action_id")
  googleConversionActionIdQualificado  String?  @map("google_conversion_action_id_qualificado")
  // Mensagem personalizada enviada pelo lead ao clicar no botão WhatsApp rastreado
  waMessageTemplate                    String?  @map("wa_message_template")
  // URL do webhook n8n anterior — a plataforma encaminha o payload para cá após processar
  n8nWebhookForwardUrl                 String?  @map("n8n_webhook_forward_url")

  contas          ClienteAtivo[]
  relatorios      RelatorioPublico[]
  crmWebhooks     ClienteCrmWebhook[]

  @@map("clientes")
}

/**
 * Webhooks auto-gerados por cliente para receber eventos CRM (1 por etapa).
 * A plataforma cria os workflows correspondentes no n8n via REST API.
 */
model ClienteCrmWebhook {
  id              BigInt    @id @default(autoincrement())
  clienteId       Int       @map("cliente_id")
  // slug da etapa. Pra base: novo_lead | nao_classificado | qualificado | perdido | concluido
  // Pra extras: slug livre derivado do label (ex: "em_negociacao")
  etapa           String
  // Label amigável que aparece no UI e vira o valor de `fb_leads.fase`
  etapaLabel      String    @map("etapa_label")
  // true = etapa adicionada manualmente (extra); false = uma das 5 base
  ehExtra         Boolean   @default(false) @map("eh_extra")
  webhookPath     String    @map("webhook_path")
  webhookUrl      String    @map("webhook_url")
  n8nWorkflowId   String    @map("n8n_workflow_id")
  tipoConversao   String?   @map("tipo_conversao")
  criadoEm        DateTime  @default(now()) @map("criado_em") @db.Timestamptz()
  atualizadoEm    DateTime  @default(now()) @map("atualizado_em") @db.Timestamptz()

  cliente         Cliente   @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@unique([clienteId, etapa])
  @@index([clienteId], map: "idx_cliente_crm_webhooks_cliente")
  @@map("cliente_crm_webhooks")
}

model RelatorioPublico {
  id          BigInt    @id @default(autoincrement())
  token       String    @unique
  clienteId   Int       @map("cliente_id")
  // semanal | quinzenal | mensal
  tipo        String
  dateFrom    DateTime  @map("date_from") @db.Date
  dateTo      DateTime  @map("date_to")   @db.Date
  criadoEm    DateTime  @default(now()) @map("criado_em") @db.Timestamptz()
  criadoPor   String?   @map("criado_por")
  expiraEm    DateTime? @map("expira_em") @db.Timestamptz()
  revogado    Boolean   @default(false)
  snapshot    Json?

  cliente     Cliente   @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId, criadoEm(sort: Desc)], map: "idx_relatorios_publicos_cliente")
  @@map("relatorios_publicos")
}

model ClienteAtivo {
  id                   Int       @id @default(autoincrement())
  nome                 String
  empresa              String
  // FK opcional: contas legadas podem ainda não estar vinculadas a um Cliente parent
  clienteId            Int?      @map("cliente_id")
  cliente              Cliente?  @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  metaAdAccountId      String?   @unique @map("meta_ad_account_id")
  whatsappAlerta       String?   @map("whatsapp_alerta")
  limiteMinimo         Decimal   @default(100.00) @map("limite_minimo") @db.Decimal(12, 2)
  moeda                String    @default("BRL")
  receberAlertaSaldo   Boolean   @default(true) @map("receber_alerta_saldo")
  ativo                Boolean   @default(true)
  criadoEm             DateTime  @default(now()) @map("criado_em") @db.Timestamptz()
  atualizadoEm         DateTime  @default(now()) @map("atualizado_em") @db.Timestamptz()

  // ── Google Ads ──────────────────────────────────────────────────────────────
  googleAdCustomerId      String?   @map("google_ad_customer_id")
  googleAdsMccId          String?   @map("google_ads_mcc_id")  // null = usar MCC padrão da agência
  limiteMinimoGoogle      Decimal   @default(100.00) @map("limite_minimo_google") @db.Decimal(12, 2)
  receberAlertaGoogle     Boolean   @default(false) @map("receber_alerta_google")

  // Cache populado pelo workflow [SYNC-GOOGLE] (a cada 1h)
  ultimoSaldoGoogle       Decimal?  @map("ultimo_saldo_google") @db.Decimal(12, 2)
  ultimoTipoContaGoogle   String?   @map("ultimo_tipo_conta_google")
  ultimoErroGoogle        String?   @map("ultimo_erro_google")
  saldoGoogleAtualizadoEm DateTime? @map("saldo_google_atualizado_em") @db.Timestamptz()

  // ── Meta Ads cache (populado pelo workflow [SYNC]) ───────────────────────
  ultimoSaldo            Decimal?  @map("ultimo_saldo") @db.Decimal(12, 2)
  ultimoTipoConta        String?   @map("ultimo_tipo_conta")
  ultimoMetodoPagamento  String?   @map("ultimo_metodo_pagamento")
  ultimoErro             String?   @map("ultimo_erro")
  saldoAtualizadoEm      DateTime? @map("saldo_atualizado_em") @db.Timestamptz()

  alertas              AlertaSaldoLog[]

  @@map("clientes_ativos")
}

model AlertaSaldoLog {
  id                Int          @id @default(autoincrement())
  clienteId         Int          @map("cliente_id")
  saldoNoMomento    Decimal      @map("saldo_no_momento") @db.Decimal(12, 2)
  limiteNoMomento   Decimal      @map("limite_no_momento") @db.Decimal(12, 2)
  whatsappDestino   String       @map("whatsapp_destino")
  status            String
  erro              String?
  enviadoEm         DateTime     @default(now()) @map("enviado_em") @db.Timestamptz()

  // Aponta para a conta (ClienteAtivo) que disparou o alerta.
  // A coluna no DB ainda se chama `cliente_id` por compatibilidade histórica;
  // a relação foi renomeada para `conta` evitar confusão com o novo entity Cliente (parent).
  conta             ClienteAtivo @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId, enviadoEm])
  @@map("alertas_saldo_log")
}

model Usuario {
  id           String   @id @default(cuid())
  nome         String
  email        String   @unique
  senhaHash    String   @map("senha_hash")
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now()) @map("criado_em") @db.Timestamptz()
  atualizadoEm DateTime @updatedAt @map("atualizado_em") @db.Timestamptz()

  @@map("usuarios")
}

// ═══════════════════════════════════════════════════════════════════════════════
// BOT MARKETING IMPULSO — Trilha B (analista + A/B test)
// Tabelas criadas via n8n setup workflow + db/011-014_bot_*.sql
// ═══════════════════════════════════════════════════════════════════════════════

model BotConversa {
  id              Int       @id @default(autoincrement())
  phone           String    @unique @db.VarChar(30)
  pushName        String?   @map("push_name") @db.VarChar(120)
  origem          String?   @db.VarChar(40)
  abVariante      String?   @map("ab_variante") @db.Char(1)
  experimentoId   Int?      @map("experimento_id")
  primeiraMsgEm   DateTime  @default(now()) @map("primeira_msg_em") @db.Timestamptz()
  ultimaMsgEm     DateTime  @default(now()) @map("ultima_msg_em") @db.Timestamptz()
  resultado       String?   @db.VarChar(20)
  motivoPerda     String?   @map("motivo_perda") @db.VarChar(40)
  fechadoEm       DateTime? @map("fechado_em") @db.Timestamptz()
  perdidoEm       DateTime? @map("perdido_em") @db.Timestamptz()
  metadata        Json      @default("{}")
  criadoEm        DateTime  @default(now()) @map("criado_em") @db.Timestamptz()
  atualizadoEm    DateTime  @default(now()) @map("atualizado_em") @db.Timestamptz()

  experimento     BotExperimentoAb? @relation(fields: [experimentoId], references: [id], onDelete: SetNull)

  @@index([resultado])
  @@index([experimentoId])
  @@index([ultimaMsgEm(sort: Desc)])
  @@map("bot_conversas")
}

model BotAnaliseSemanal {
  id              Int       @id @default(autoincrement())
  periodoInicio   DateTime  @map("periodo_inicio") @db.Date
  periodoFim      DateTime  @map("periodo_fim") @db.Date
  totalConversas  Int       @default(0) @map("total_conversas")
  fechadas        Int       @default(0)
  perdidas        Int       @default(0)
  emAberto        Int       @default(0) @map("em_aberto")
  taxaFechamento  Decimal?  @map("taxa_fechamento") @db.Decimal(5, 4)
  resumoExecutivo String?   @map("resumo_executivo")
  payload         Json
  status          String    @default("pendente") @db.VarChar(20)
  decididoPor     String?   @map("decidido_por") @db.VarChar(120)
  decididoEm      DateTime? @map("decidido_em") @db.Timestamptz()
  decisaoNotas    String?   @map("decisao_notas")
  criadoEm        DateTime  @default(now()) @map("criado_em") @db.Timestamptz()
  atualizadoEm    DateTime  @default(now()) @map("atualizado_em") @db.Timestamptz()

  experimentos    BotExperimentoAb[]

  @@unique([periodoInicio, periodoFim], map: "uniq_bot_analises_periodo")
  @@index([status])
  @@map("bot_analises_semanais")
}

model BotExperimentoAb {
  id              Int       @id @default(autoincrement())
  analiseId       Int?      @map("analise_id")
  nome            String    @db.VarChar(200)
  hipotese        String?
  modoAlvo        String    @map("modo_alvo") @db.VarChar(20)
  varianteA       String    @map("variante_a")
  varianteB       String    @map("variante_b")
  metricaAlvo     String    @map("metrica_alvo") @db.VarChar(40)
  amostraMinima   Int       @default(20) @map("amostra_minima")
  status          String    @default("rodando") @db.VarChar(20)
  dataInicio      DateTime  @default(now()) @map("data_inicio") @db.Timestamptz()
  dataFim         DateTime? @map("data_fim") @db.Timestamptz()
  resultadoA      Json?     @map("resultado_a")
  resultadoB      Json?     @map("resultado_b")
  vencedor        String?   @db.Char(1)
  promovidoEm     DateTime? @map("promovido_em") @db.Timestamptz()
  criadoEm        DateTime  @default(now()) @map("criado_em") @db.Timestamptz()
  atualizadoEm    DateTime  @default(now()) @map("atualizado_em") @db.Timestamptz()

  analise         BotAnaliseSemanal? @relation(fields: [analiseId], references: [id], onDelete: SetNull)
  conversas       BotConversa[]

  @@index([status])
  @@index([analiseId])
  @@map("bot_experimentos_ab")
}

model ConversaHandoff {
  phone           String    @id @db.VarChar(30)
  handoffActive   Boolean   @default(false) @map("handoff_active")
  motivo          String?   @db.VarChar(50)
  notas           String?
  criadoEm        DateTime  @default(now()) @map("criado_em") @db.Timestamptz()
  updatedAt       DateTime  @default(now()) @map("updated_at") @db.Timestamptz()
  reativadoEm     DateTime? @map("reativado_em") @db.Timestamptz()

  @@map("conversas_handoff")
}

// ═══════════════════════════════════════════════════════════════════════════════
// CRM PRÓPRIO — Mensagens capturadas via Evolution API
// Tabelas criadas via db/023_crm_mensagens.sql
// ═══════════════════════════════════════════════════════════════════════════════

model GoogleAttribution {
  id           BigInt    @id @default(autoincrement())
  code         String    @unique
  clientKey    String    @map("client_key")
  gclid        String?
  wbraid       String?
  gbraid       String?
  utmSource    String?   @map("utm_source")
  utmMedium    String?   @map("utm_medium")
  utmCampaign  String?   @map("utm_campaign")
  utmContent   String?   @map("utm_content")
  utmTerm      String?   @map("utm_term")
  leadId       String?   @map("lead_id")
  ip           String?
  userAgent    String?   @map("user_agent")
  criadoEm     DateTime  @default(now()) @map("criado_em") @db.Timestamptz()
  vinculadoEm  DateTime? @map("vinculado_em") @db.Timestamptz()

  @@index([clientKey, criadoEm(sort: Desc)])
  @@index([leadId])
  @@map("google_attribution")
}

model CrmMensagem {
  id             BigInt    @id @default(autoincrement())
  // Telefone do lead no formato Evolution (ex: "556384823503") — serve como lead_id
  leadId         String    @map("lead_id")
  clientKey      String    @map("client_key")
  // "lead" = recebida do WhatsApp | "atendente" = enviada pelo painel
  de             String
  // text | image | audio | video | document | sticker
  tipo           String    @default("text")
  conteudo       String?
  mediaUrl       String?   @map("media_url")
  // ID único da mensagem na Evolution API — evita duplicatas
  evolutionMsgId String?   @unique @map("evolution_msg_id")
  recebidaEm     DateTime  @default(now()) @map("recebida_em") @db.Timestamptz()
  criadoEm       DateTime  @default(now()) @map("criado_em") @db.Timestamptz()

  @@index([leadId, recebidaEm(sort: Desc)])
  @@index([clientKey, recebidaEm(sort: Desc)])
  @@map("crm_mensagens")
}
