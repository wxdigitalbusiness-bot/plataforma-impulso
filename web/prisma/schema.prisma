// Plataforma Impulso — Phase 2
// Mapeia tabelas existentes do Postgres (criadas via n8n) + adiciona usuarios

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Cliente {
  id              Int       @id @default(autoincrement())
  nome            String
  // Razão social ou marca-mãe (compartilhada por todas as contas vinculadas)
  empresa         String?
  // WhatsApp único pra alertas de qualquer conta deste cliente
  whatsappAlerta  String?   @map("whatsapp_alerta")
  // Tipo de serviço prestado pela agência. Valores: panfletagem_digital | gestao_trafego | impulso_360
  tipoServico     String?   @map("tipo_servico")
  ativo           Boolean   @default(true)
  criadoEm        DateTime  @default(now()) @map("criado_em") @db.Timestamptz()
  atualizadoEm    DateTime  @default(now()) @map("atualizado_em") @db.Timestamptz()

  contas          ClienteAtivo[]

  @@map("clientes")
}

model ClienteAtivo {
  id                   Int       @id @default(autoincrement())
  nome                 String
  empresa              String
  // FK opcional: contas legadas podem ainda não estar vinculadas a um Cliente parent
  clienteId            Int?      @map("cliente_id")
  cliente              Cliente?  @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  metaAdAccountId      String?   @unique @map("meta_ad_account_id")
  whatsappAlerta       String?   @map("whatsapp_alerta")
  limiteMinimo         Decimal   @default(100.00) @map("limite_minimo") @db.Decimal(12, 2)
  moeda                String    @default("BRL")
  receberAlertaSaldo   Boolean   @default(true) @map("receber_alerta_saldo")
  ativo                Boolean   @default(true)
  criadoEm             DateTime  @default(now()) @map("criado_em") @db.Timestamptz()
  atualizadoEm         DateTime  @default(now()) @map("atualizado_em") @db.Timestamptz()

  // ── Google Ads ──────────────────────────────────────────────────────────────
  googleAdCustomerId      String?   @map("google_ad_customer_id")
  googleAdsMccId          String?   @map("google_ads_mcc_id")  // null = usar MCC padrão da agência
  limiteMinimoGoogle      Decimal   @default(100.00) @map("limite_minimo_google") @db.Decimal(12, 2)
  receberAlertaGoogle     Boolean   @default(false) @map("receber_alerta_google")

  // Cache populado pelo workflow [SYNC-GOOGLE] (a cada 1h)
  ultimoSaldoGoogle       Decimal?  @map("ultimo_saldo_google") @db.Decimal(12, 2)
  ultimoTipoContaGoogle   String?   @map("ultimo_tipo_conta_google")
  ultimoErroGoogle        String?   @map("ultimo_erro_google")
  saldoGoogleAtualizadoEm DateTime? @map("saldo_google_atualizado_em") @db.Timestamptz()

  // ── Meta Ads cache (populado pelo workflow [SYNC]) ───────────────────────
  ultimoSaldo            Decimal?  @map("ultimo_saldo") @db.Decimal(12, 2)
  ultimoTipoConta        String?   @map("ultimo_tipo_conta")
  ultimoMetodoPagamento  String?   @map("ultimo_metodo_pagamento")
  ultimoErro             String?   @map("ultimo_erro")
  saldoAtualizadoEm      DateTime? @map("saldo_atualizado_em") @db.Timestamptz()

  alertas              AlertaSaldoLog[]

  @@map("clientes_ativos")
}

model AlertaSaldoLog {
  id                Int          @id @default(autoincrement())
  clienteId         Int          @map("cliente_id")
  saldoNoMomento    Decimal      @map("saldo_no_momento") @db.Decimal(12, 2)
  limiteNoMomento   Decimal      @map("limite_no_momento") @db.Decimal(12, 2)
  whatsappDestino   String       @map("whatsapp_destino")
  status            String
  erro              String?
  enviadoEm         DateTime     @default(now()) @map("enviado_em") @db.Timestamptz()

  // Aponta para a conta (ClienteAtivo) que disparou o alerta.
  // A coluna no DB ainda se chama `cliente_id` por compatibilidade histórica;
  // a relação foi renomeada para `conta` evitar confusão com o novo entity Cliente (parent).
  conta             ClienteAtivo @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId, enviadoEm])
  @@map("alertas_saldo_log")
}

model Usuario {
  id           String   @id @default(cuid())
  nome         String
  email        String   @unique
  senhaHash    String   @map("senha_hash")
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now()) @map("criado_em") @db.Timestamptz()
  atualizadoEm DateTime @updatedAt @map("atualizado_em") @db.Timestamptz()

  @@map("usuarios")
}
